# Brev inference endpoint
BREV_ENDPOINT=https://<your-brev-endpoint>.brevlab.com

# NVIDIA API
NVIDIA_API_KEY=

# Nemotron model names
NEMOTRON_SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_NANO_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Third-source config (default: TWOSIDES SQLite)
THIRD_SOURCE=twosides
TWOSIDES_DB_PATH=./data/twosides.sqlite

# OpenFDA API key (optional — unauthenticated tier works for low volume)
OPENFDA_API_KEY=

ACUITY_API_BASE_URL=https://<your-deployment>.vercel.app
BRAVE_API_KEY=

# Telegram bot — required by skills/reminder
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key-from-dashboard>
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-from-dashboard>

# NemoClaw authentication — no static key needed.
# Each user generates their Personal Access Token via the React app (My Profile → NemoClaw Token).
# Tokens are stored in profiles.pat and looked up on each request.
