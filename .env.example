# Brev inference endpoint
BREV_ENDPOINT=https://<your-brev-endpoint>.brevlab.com

# NVIDIA API
NVIDIA_API_KEY=

# Nemotron model names
NEMOTRON_SUPER_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_NANO_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Third-source config (default: TWOSIDES SQLite)
THIRD_SOURCE=twosides
TWOSIDES_DB_PATH=./data/twosides.sqlite

# OpenFDA API key (optional — unauthenticated tier works for low volume)
OPENFDA_API_KEY=

# Frontend / Vite
VITE_API_URL=http://localhost:8080/
VITE_SUPABASE_URL=https://<project>.supabase.co/
VITE_SUPABASE_ANON_KEY=

# Google OAuth (for frontend auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Acuity backend API base URL (used by skills/analyze)
# Falls back to http://localhost:8081 if unset
ACUITY_API_BASE_URL=https://<your-deployment>.vercel.app

# Acuity Personal Access Token — required by all skills that call the Acuity API
# Sent as the x-api-key header. Generate from your Acuity account settings.
ACUITY_PAT=

# Brave Search API — required by skills/deep_research
BRAVE_API_KEY=

# Telegram bot — required by skills/reminder
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Future: Supabase service key (required by skills/db when implemented)
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_KEY=
